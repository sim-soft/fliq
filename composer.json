{
  "name": "simsoft/fliq",
  "description": "FLIQ — Fast, Lightweight, Independent Query Builder. High-performance Active Record ORM for MySQL/MariaDB, PostgreSQL, and SQLite. Zero-allocation query builder, nested eager loading, soft deletes, and N+1 detection built-in.",
  "keywords": [
    "orm",
    "active-record",
    "query-builder",
    "database",
    "mysql",
    "mariadb",
    "postgresql",
    "pdo",
    "model",
    "eloquent-alternative",
    "eager-loading",
    "soft-delete",
    "persistence",
    "php-orm"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "V. Zang, Loo",
      "email": "vzangloo@7mayday.com",
      "role": "Developer"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": "^8.1",
    "ext-pdo": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpmd/phpmd": "^2.15",
    "phpstan/phpstan": "^2.1",
    "squizlabs/php_codesniffer": "^3.13"
  },
  "suggest": {
    "ext-mysqli": "Required for MySQLi driver support",
    "simsoft/validator": "For model validation support"
  },
  "autoload": {
    "psr-4": {
      "Simsoft\\DB\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Models\\": "tests/Models",
      "Integration\\": "tests/Integration"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "qc": [
      "phpstan analyse --memory-limit=512M",
      "phpmd src text phpmd.xml"
    ],
    "qc-fix": "phpcbf --standard=PSR12 src",
    "test": "phpunit tests"
  }
}
